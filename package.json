{"name": "ps5-vault","version": "2.1.0","description": "PS5 game library manager — scan, organise and transfer games via USB or FTP","main": "main.js","author": "PS5 Vault","license": "MIT","scripts": {"start":          "electron .","build":          "electron-builder --win portable","build:all":      "electron-builder --win --mac --linux","build:portable": "electron-builder --win portable","build:installer":"electron-builder --win nsis"},"dependencies": {"basic-ftp": "^5.0.5","readdirp":  "^3.6.0"},"devDependencies": {"electron":         "^29.0.0","electron-builder": "^24.13.3"},"build": {"appId":       "com.ps5vault.app","productName": "PS5 Vault","copyright":   "Copyright © 2025 PS5 Vault","asar":        true,"files": ["main.js","preload.js","renderer.js","ftp.js","utils.js","datalist-init.js","help.js","index.html","ui-overrides.css","assets/**/*","!**/*.bak","!**/*.bak2","!**/*.pre_perf","!**/node_modules/.cache/**"],"win": {"target": [{ "target": "portable", "arch": ["x64"] }],"icon": "assets/icon.ico","artifactName": "${productName}-${version}-portable.exe"},"portable": {"requestExecutionLevel": "user","unpackDirName": "ps5vault"},"nsis": {"oneClick":             false,"allowToChangeInstallationDirectory": true,"installerIcon":        "assets/icon.ico","uninstallerIcon":      "assets/icon.ico","artifactName":         "${productName}-${version}-setup.exe"},"mac": {"target": "dmg","icon":   "assets/icon.icns","category": "public.app-category.utilities"},"linux": {"target": "AppImage","icon":   "assets/icon.png","category": "Utility"},"directories": {"output": "dist","buildResources": "assets"}}}